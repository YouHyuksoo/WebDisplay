# PowerBuilder 원본 소스 (참조용, git 추적 제외)
/SOLUM MES_DISP/

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# DB config (contains credentials)
/config/database.json

# Slack settings (contains webhook URL)
/data/slack-settings.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# Claude Code 런타임 lock
/.claude/scheduled_tasks.lock

# AI 챗 세션 임시 파일 (원자적 쓰기 .tmp-*)
/data/ai-chats/

# graphify 지식 그래프 (graphify update . 로 재생성 가능)
/graphify-out/
